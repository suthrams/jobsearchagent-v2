# ─── Secrets & credentials ───────────────────────────────────────────────────
.env
.env.*
*.env

# ─── Personal data ────────────────────────────────────────────────────────────
# Your resume PDF — contains personal PII, never commit
resume.pdf
*.pdf

# Parsed resume profile — extracted from resume, contains name/email/work history
data/profile.json

# Job search database — contains your full search and application history
data/jobs.db
data/*.db

# Tailored resumes and run logs — contain personal content
output/

# ─── Streamlit ────────────────────────────────────────────────────────────────
# Contains auth tokens from streamlit login
.streamlit/credentials.toml

# ─── LinkedIn inbox ───────────────────────────────────────────────────────────
# Processed automatically — no need to commit, and may contain private URLs
inbox/linkedin.txt

# ─── Mermaid folder ───────────────────────────────────────────────────────────
# Processed automatically — no need to commit
mermaid/

# ─── Config (user-specific, never commit) ────────────────────────────────────
config/config.yaml

